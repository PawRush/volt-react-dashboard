{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "npm run deploy:preview",
    "deploy:preview": "cdk deploy --all --require-approval never --progress events",
    "deploy:pipeline": "cdk deploy DemoVoltReactPipelineStack --context codeConnectionArn=arn:aws:codeconnections:us-east-1:126593893432:connection/22d78f95-9da1-4de3-a9d5-c511e9807894 --context repositoryName=PawRush/volt-react-dashboard --context branchName=demo-deploy-to-aws --require-approval never --progress events",
    "destroy:pipeline": "cdk destroy DemoVoltReactPipelineStack --context codeConnectionArn=arn:aws:codeconnections:us-east-1:126593893432:connection/22d78f95-9da1-4de3-a9d5-c511e9807894",
    "destroy": "cdk destroy --all",
    "synth": "cdk synth",
    "diff": "cdk diff"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1101.0",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-solutions-constructs/aws-cloudfront-s3": "^2.97.0",
    "aws-cdk-lib": "^2.235.0",
    "constructs": "^10.4.4"
  }
}
